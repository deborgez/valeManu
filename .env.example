# Connection string do banco Postgres (Neon) — a versão "pooled" (com -pooler no host),
# usada pela aplicação em runtime. Pegue em neon.tech no seu projeto ou na aba
# Storage do projeto na Vercel, se tiver criado o Postgres por lá.
DATABASE_URL="postgresql://usuario:senha@ep-xxxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Connection string SEM o pooler — usada só na hora de rodar as migrações.
DATABASE_URL_UNPOOLED="postgresql://usuario:senha@ep-xxxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Chave secreta do NextAuth — gere uma com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-chave-aleatoria-forte"

# URL pública do site (em produção, a URL do domínio na Vercel)
NEXTAUTH_URL="https://seu-projeto.vercel.app"

# Token de leitura/escrita do Vercel Blob — criado junto com o Blob Store no dashboard da Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxx"
